generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  intents       Intent[]
  memoryProfile MemoryProfile?
  events        Event[]

  @@map("users")
}

model Session {
  id              String    @id @default(cuid())
  userId          String
  token           String    @unique
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  lastActiveAt    DateTime?
  deviceUserAgent String?
  deviceIp        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Intent {
  id           String   @id @default(cuid())
  userId       String
  rawInput     String
  budgetCents  Int
  zipCode      String
  servings     Int      @default(4)
  dietaryFlags String[] @default([])
  mealCount    Int      @default(5)
  createdAt    DateTime @default(now())

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals Meal[]

  @@index([userId])
  @@map("intents")
}

model Meal {
  id                  String   @id @default(cuid())
  intentId            String
  name                String
  description         String
  servings            Int
  prepTimeMinutes     Int
  cookTimeMinutes     Int
  dietaryFlags        String[] @default([])
  estimatedCostCents  Int
  ingredientsJson     Json
  approved            Boolean  @default(false)
  createdAt           DateTime @default(now())

  intent Intent @relation(fields: [intentId], references: [id], onDelete: Cascade)
  carts  Cart[]

  @@index([intentId])
  @@map("meals")
}

model Cart {
  id                    String   @id @default(cuid())
  userId                String
  mealId                String?
  provider              String
  storeId               String
  storeName             String
  itemsJson             Json
  subtotalCents         Int
  estimatedDeliveryFee  Int
  estimatedTotalCents   Int
  checkoutUrl           String?
  missingIngredients    String[] @default([])
  coverageScore         Float
  createdAt             DateTime @default(now())

  meal Meal? @relation(fields: [mealId], references: [id])

  @@index([userId])
  @@map("carts")
}

model MemoryProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  pastIntents         Json     @default("[]")
  acceptedMeals       Json     @default("[]")
  rejectedSubs        Json     @default("[]")
  dietaryPatterns     Json     @default("{}")
  budgetBehavior      Json     @default("{}")
  preferredStores     Json     @default("[]")
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memory_profiles")
}

model Checkpoint {
  id        String   @id @default(cuid())
  flowId    String
  step      String
  status    String   @default("pending")
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([flowId, step])
  @@map("checkpoints")
}

model Job {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("pending")
  payload     Json
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  runAt       DateTime @default(now())
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, runAt])
  @@index([type])
  @@map("jobs")
}

model Event {
  id        String   @id @default(cuid())
  type      String
  userId    String
  zipCode   String?
  payload   Json
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([timestamp])
  @@map("events")
}

model Recipe {
  id              String   @id @default(cuid())
  name            String
  price           Float
  category        String
  tags            String[]
  imageUrl        String?
  servings        Int?
  description     String?
  cuisine         String?
  cookTimeMinutes Int?
  prepTimeMinutes Int?
  calories        Int?
  externalId      String?  @unique
  sourceUrl       String?
  createdAt       DateTime @default(now())

  savedBy       SavedRecipe[]
  mealPlanItems MealPlanItem[]
  ingredients   RecipeIngredient[]
  instructions  RecipeInstruction[]
  nutrition     RecipeNutrition?
  views         RecipeView[]

  @@index([category])
  @@index([externalId])
  @@map("recipes")
}

model RecipeIngredient {
  id         String  @id @default(cuid())
  recipeId   String
  name       String
  measure    String?
  normalized String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@map("recipe_ingredients")
}

model RecipeInstruction {
  id       String @id @default(cuid())
  recipeId String
  step     Int
  text     String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@map("recipe_instructions")
}

model RecipeNutrition {
  id        String @id @default(cuid())
  recipeId  String @unique
  calories  Int?
  proteinG  Float?
  fatG      Float?
  carbsG    Float?
  fiberG    Float?
  sodiumMg  Float?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_nutrition")
}

model RecipeView {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([createdAt])
  @@map("recipe_views")
}

model SearchQuery {
  id          String   @id @default(cuid())
  query       String
  userId      String?
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("search_queries")
}

model SavedRecipe {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
  @@map("saved_recipes")
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  items MealPlanItem[]

  @@index([userId])
  @@map("meal_plans")
}

model MealPlanItem {
  id         String   @id @default(cuid())
  mealPlanId String
  recipeId   String
  day        String
  createdAt  DateTime @default(now())

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
  @@map("meal_plan_items")
}

model GroceryStore {
  id              String  @id @default(cuid())
  name            String
  zipCode         String
  address         String?
  type            String  // walmart | kroger | target | local
  priceMultiplier Float   @default(1.0)

  @@index([zipCode])
  @@map("grocery_stores")
}

model UserStoreSelection {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  zipCode   String
  createdAt DateTime @default(now())

  @@unique([userId])
  @@index([userId])
  @@map("user_store_selections")
}

model Order {
  id                  String   @id @default(cuid())
  userId              String
  stripeSessionId     String   @unique
  stripePaymentIntent String?
  status              String   @default("pending")
  amountTotal         Int      @default(0)
  currency            String   @default("usd")
  lineItemsJson       Json
  metadataJson        Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}
